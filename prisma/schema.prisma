// HV Jewelers — Prisma schema.
//
// Post-catalog-retirement (commit c8adbff). The Shopify Storefront API
// owns products, inventory, collections, carts, orders, customers, and
// shipping. Prisma here is reduced to the authoritative store for
// in-app auth (Auth.js tables) and the audit log.
//
// The DB still contains the legacy tables (Product, Cart, Order,
// InventoryItem, etc.) from before the retirement. They are unused by
// any code path but will only be physically dropped when the operator
// runs the migration generated from this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: runtime traffic goes through the Transaction pooler
  // (DATABASE_URL); migrations need real prepared statements, so
  // Prisma uses DIRECT_URL (the Session pooler) for `prisma migrate`.
  directUrl = env("DIRECT_URL")
}

// ════════════════════════════════════════════════════════════════════════
//  Auth — Users, Roles, Auth.js tables
// ════════════════════════════════════════════════════════════════════════

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  role           UserRole  @default(CUSTOMER)
  /// bcrypt hash (or argon2id when migrated). Nullable so OAuth-only
  /// accounts are supported without a password record.
  passwordHash   String?
  marketingOptIn Boolean   @default(false)
  /// Soft-disable. Disabled users cannot authenticate.
  isDisabled     Boolean   @default(false)
  /// Last successful sign-in. Surfaces in the admin user list and
  /// as a forensic signal in the audit log.
  lastSignInAt   DateTime?
  /// SHA-256 hex of a one-time staff-invite token. Raw token only
  /// ever lives in the invite email; verification hashes the incoming
  /// value. Cleared when the user completes password set.
  inviteTokenHash  String?
  inviteExpiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ════════════════════════════════════════════════════════════════════════
//  Audit log — admin and auth mutations
// ════════════════════════════════════════════════════════════════════════

model AuditLog {
  id           String  @id @default(cuid())
  actorId      String?
  /// Dot-namespaced action, e.g., "user.role.change", "user.invite",
  /// "auth.login". Free-form string; document conventions in code.
  action       String
  resourceType String
  resourceId   String?
  before       Json?
  after        Json?
  /// Request IP at time of action (for forensic review).
  ip           String?
  userAgent    String?
  context      Json?

  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt])
}

// ════════════════════════════════════════════════════════════════════════
//  Marketing — pre-launch / newsletter subscribers
// ════════════════════════════════════════════════════════════════════════

/// Email-capture list for the storefront ("be first to shop the collection")
/// and the social funnel. Independent of User/Auth.js — a subscriber is not
/// an account. status: 'subscribed' (default, single opt-in) | 'unsubscribed'.
/// confirmedAt is reserved for a future double-opt-in step.
model Subscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  /// Where the signup came from: 'storefront-footer', 'storefront-hero',
  /// 'pinterest', etc. Lets us attribute the funnel later.
  source      String    @default("storefront")
  status      String    @default("subscribed")
  ip          String?
  userAgent   String?
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}
