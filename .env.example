# HV Jewelers — environment template.
# Copy to .env.local for local development. Never commit .env.local.
# Production values live in Vercel (or equivalent) environment settings only.

# ─── Site ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Auth (Auth.js v5) — Phase 4 wiring ──────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Database (Postgres) — Phase 3 schema ────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/hv_jewelers"

# ─── Cloudinary — image hosting + signed uploads ─────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─── Upstash Redis — rate limiting ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Shopify Storefront API — headless catalog + checkout ───────────────
# Store domain that serves the Storefront API, e.g. hv-jewelers.myshopify.com
# (use the .myshopify.com domain even if you have a custom one). NOT a secret.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=""
# Storefront API access token: Shopify admin → Settings → Apps and sales
# channels → Develop apps → (your app) → API credentials → Storefront API
# access token. Read-only, scoped to products/collections/cart — but still
# keep it in env, never in code.
SHOPIFY_STOREFRONT_TOKEN=""
# Optional — pin the Storefront API version (code defaults to 2025-10).
SHOPIFY_STOREFRONT_API_VERSION="2025-10"
# Shared secret to verify Shopify webhook signatures (/api/shopify/webhook).
SHOPIFY_WEBHOOK_SECRET=""

# ─── Resend — transactional email ──────────────────────────────────────
RESEND_API_KEY=""                    # re_…
EMAIL_FROM_ADDRESS="Hong Vi <concierge@hvjewelers.com>"
EMAIL_REPLY_TO=""                    # optional; defaults to From

# ─── Vercel Cron shared secret ─────────────────────────────────────────
# Generate: openssl rand -base64 32
# Set the same value on Vercel (Settings → Environment Variables). Vercel
# Cron sends it as `Authorization: Bearer ${CRON_SECRET}` on every call.
CRON_SECRET=""

# ─── Sentry (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
