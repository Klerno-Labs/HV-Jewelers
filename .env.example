# HV Jewelers — environment template.
# Copy to .env.local for local development. Never commit .env.local.
# Production values live in Vercel (or equivalent) environment settings only.

# ─── Site ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Auth (Auth.js v5) — Phase 4 wiring ──────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Database (Postgres) — Phase 3 schema ────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/hv_jewelers"

# ─── Cloudinary — image hosting + signed uploads ─────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─── Upstash Redis — rate limiting ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Stripe — checkout + payments ──────────────────────────────────────
# Generate via Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=""        # sk_test_… in dev, sk_live_… in prod
# Generate via Stripe CLI (`stripe listen`) or Stripe Dashboard webhook config.
STRIPE_WEBHOOK_SECRET=""    # whsec_…
# Enable only after configuring Stripe Tax in your Stripe account.
STRIPE_TAX_ENABLED="false"

# ─── Resend — transactional email ──────────────────────────────────────
RESEND_API_KEY=""                    # re_…
EMAIL_FROM_ADDRESS="Hong Vi <concierge@hvjewelers.com>"
EMAIL_REPLY_TO=""                    # optional; defaults to From

# ─── Shippo — shipping labels ──────────────────────────────────────────
SHIPPO_API_KEY=""                    # shippo_test_… in dev, shippo_live_… in prod
SELLER_SHIP_FROM_NAME=""
SELLER_SHIP_FROM_STREET1=""
SELLER_SHIP_FROM_CITY=""
SELLER_SHIP_FROM_STATE=""            # two-letter US state code
SELLER_SHIP_FROM_POSTAL=""
SELLER_SHIP_FROM_PHONE=""

# ─── Vercel Cron shared secret ─────────────────────────────────────────
# Generate: openssl rand -base64 32
# Set the same value on Vercel (Settings → Environment Variables). Vercel
# Cron sends it as `Authorization: Bearer ${CRON_SECRET}` on every call.
CRON_SECRET=""

# ─── Sentry (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
